**/UserConfigs/Host.conf
jakoolithyprl/**/.initial_startup_done
**/wallpaper_effects/.wallpaper_current
**/wallpaper_effects/.wallpaper_modified
**/wallust/wallust-hyprland.conf
jakoolithyprl/**/monitors.conf
jakoolithyprl/**/workspaces.conf
jakoolithyprl/active/

# Profile trees should contain only real profile-specific overrides. The shared
# JaKooLit files live in common/ and active/ is generated by set-hypr-profile.sh.
jakoolithyprl/desktop/**
!jakoolithyprl/desktop/
!jakoolithyprl/desktop/UserConfigs/
!jakoolithyprl/desktop/UserConfigs/Host.conf.example
!jakoolithyprl/desktop/UserScripts/
!jakoolithyprl/desktop/UserScripts/WallpaperAutoChange.sh
!jakoolithyprl/desktop/UserScripts/WallpaperRandom.sh

jakoolithyprl/laptop/**
!jakoolithyprl/laptop/
!jakoolithyprl/laptop/UserConfigs/
!jakoolithyprl/laptop/UserConfigs/Host.conf.example
!jakoolithyprl/laptop/UserScripts/
!jakoolithyprl/laptop/UserScripts/WallpaperAutoChange.sh
!jakoolithyprl/laptop/UserScripts/WallpaperRandom.sh

.codex
